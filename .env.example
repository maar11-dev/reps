# Reps environment variables.
# Copy this file to `.env.local` and fill in real values to go live.
# `.env.local` is gitignored — never commit real keys.

# ---- AI generation toggle ----
# When "true" (the default), /api/generate returns a deterministic MOCK plan and
# never calls a real LLM. Flip to "false" AND set a provider key to go live.
REPS_USE_MOCK=true

# ---- Provider keys (server-only, never exposed to the client) ----
# Groq is the preferred live provider (fast, generous free tier). Required only
# when REPS_USE_MOCK=false. Get one at https://console.groq.com/keys
GROQ_API_KEY=
# Optional: override the Groq model used by generateObject.
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI is the fallback provider, used only if GROQ_API_KEY is unset.
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ---- Persistence + Auth (Supabase, milestone 2) ----
# From your Supabase project settings → API. The anon key is public by design;
# Row Level Security (supabase/migrations/0001_saved_plans.sql) protects the data,
# so server code uses the anon key + the user's session — never the service role.
# Leave BOTH blank to run with the in-memory fallback (no accounts, DEV_USER_ID).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
